# ── Database ──────────────────────────────────────────────────────────────────
# Neon (PostgreSQL) — for Vercel testing:
# DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/sawari?sslmode=require"
#
# Namecheap (MySQL) — for production:
# DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/sawari_book"
#
# To switch: change provider in prisma/schema.prisma  (postgresql ↔ mysql)
#            and update this URL
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sawari_book"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this"

# ── API ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=""

# ── Push Notifications (required in production) ───────────────────────────────
# Generate VAPID keys and set both public/private values.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# Email only, without mailto prefix (example: alerts@yourcompany.com)
VAPID_CONTACT_EMAIL=""
